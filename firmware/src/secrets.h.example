// LẤY PLANT_CODE:
//   Admin vào Dashboard → Tạo chậu cây mới
//   Backend sinh ra plant_code ngẫu nhiên (ví dụ: "A7B3F2K9")
// =============================================================

// --- WiFi (dùng để test lần đầu hoặc fallback nếu NVS trống) ---
const char* WIFI_SSID = "TEN_WIFI_CUA_BAN";
const char* WIFI_PASS = "MAT_KHAU_WIFI";

// --- Plant Code mặc định (lấy từ Admin Dashboard) ---
const char* DEFAULT_PLANT_CODE = "PLANT_CODE";  // ← Điền vào đây
const char* DEFAULT_VERIFY_CODE = "123456";     // ← Điền vào đây

// --- Server ---
// Môi trường test (mock server cục bộ): "http://<IP_MAY_TINH>:8000"
//   Tìm IP bằng lệnh: ipconfig → xem IPv4 Address ở mục Wi-Fi
//   Mở cổng firewall: netsh advfirewall firewall add rule name="MockServer" dir=in action=allow protocol=TCP localport=8000
//
// Môi trường production (backend thật): "https://your-domain.com"
const char* SERVER_HOST = "http://192.168.1.x:8000";

// --- Pin cảm biến (không cần thay đổi nếu đấu dây theo sơ đồ trong README) ---
#define PIN_DHT22       4    // DHT22 data pin
#define PIN_SOIL_ADC    34   // Soil moisture (ADC, input only)
#define PIN_OLED_SDA    21
#define PIN_OLED_SCL    22

// --- Thời gian ---
#define TELEMETRY_INTERVAL_MS  60000UL   // 60 giây (đổi sang 10000 để demo nhanh hơn)
